model Report {
  id            Int      @id @default(autoincrement())
  participantId Int
  motif         String
  details       String?
  tournoiId     Int
  reporterId    Int
  date          DateTime @default(now())

  participant   User     @relation("ReportedUser", fields: [participantId], references: [id], onDelete: Cascade)
  reporter      User     @relation("ReporterUser", fields: [reporterId], references: [id], onDelete: Cascade)
  tournament    Tournament @relation(fields: [tournoiId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@index([reporterId])
  @@index([tournoiId])
}
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Match {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  round        Int
  matchIndex   Int
  winnerId     Int?
  playerId     Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime?  @updatedAt
  player       User?      @relation("PlayerMatches", fields: [playerId], references: [id])
  tournament   Tournament @relation("TournamentMatches", fields: [tournamentId], references: [id], onDelete: Cascade)
  winner       User?      @relation("MatchWinner", fields: [winnerId], references: [id])

  @@index([playerId])
  @@index([tournamentId])
  @@index([winnerId])
}

model TournamentParticipant {
  id           Int        @id @default(autoincrement())
  tournamentId Int
  userId       Int
  joinedAt     DateTime   @default(now())
  isActive     Boolean    @default(true)
  
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
}

model Tournament {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  game         Game
  date         DateTime
  maxPlayers   Int
  createdById  Int
  winnerId     Int?
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now())
  matches      Match[]  @relation("TournamentMatches")
  createdBy    User     @relation("CreatedTournaments", fields: [createdById], references: [id], onDelete: Cascade)
  winner       User?    @relation("TournamentWinner", fields: [winnerId], references: [id])
  participants TournamentParticipant[]

  reports      Report[]

  @@index([createdById])
  @@index([winnerId])
}

model User {
  id                 Int          @id @default(autoincrement())
  pseudo             String       @unique
  email              String       @unique
  password           String
  avatarUrl          String       @default("")
  emailVerifiedAt    DateTime?
  emailVerificationTokenHash String? @unique
  emailVerificationTokenExpiresAt DateTime?
  passwordResetTokenHash String? @unique
  passwordResetTokenExpiresAt DateTime?
  createdAt          DateTime     @default(now())
  tournamentsWon     Int          @default(0)
  matchesWon         Int          @default(0)
  ranking            Int          @default(0)
  role               Role         @default(USER)
  isDeleted          Boolean      @default(false)

  tokensUsedThisMonth Int          @default(0)
  tokensMonthStart    DateTime?
  planId             Int?
  plan               Plan?        @relation(fields: [planId], references: [id])
  paypalSubscriptionId String?

  matchHistory       Match[]      @relation("PlayerMatches")
  matchesWonList     Match[]      @relation("MatchWinner")
  createdTournaments Tournament[] @relation("CreatedTournaments")
  tournamentsVictory Tournament[] @relation("TournamentWinner")
  tournamentParticipations TournamentParticipant[]
  contactRequests     ContactRequest[]

  reportsReceived    Report[]     @relation("ReportedUser")
  reportsSent        Report[]     @relation("ReporterUser")
}

model ContactRequest {
  id        Int            @id @default(autoincrement())
  userId    Int
  message   String         @db.Text
  status    ContactStatus  @default(EN_COURS)
  createdAt DateTime       @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

enum ContactStatus {
  EN_COURS
  TRAITE
}

model Plan {
  id            Int      @id @default(autoincrement())
  name          String
  slug          String   @unique
  priceCents    Int
  currency      String   @default("EUR")
  tokensPerMonth Int @default(3)
  paypalPlanId  String?
  createdAt     DateTime @default(now())

  users         User[]
}

enum Game {
  LEAGUE_OF_LEGENDS
  VALORANT
  OVERWATCH
  FALL_GUYS
  MARVELS_RIVALS
  MINECRAFT
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
}
