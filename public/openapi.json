    "/api/cron/reset-tokens": {
      "get": {
        "tags": ["Cron"],
        "summary": "Réinitialiser les tokens mensuels de tous les utilisateurs",
        "description": "Route appelée automatiquement le 1er de chaque mois. Nécessite le header Authorization avec la valeur du CRON_SECRET.",
        "parameters": [
          { "name": "Authorization", "in": "header", "required": true, "schema": { "type": "string" }, "description": "Bearer <CRON_SECRET>" }
        ],
        "responses": {
