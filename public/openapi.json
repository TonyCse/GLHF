          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Liste des utilisateurs disponibles" }
        }
      }
    },
    "/api/admin/payments": {
      "get": {
        "tags": ["Admin - Paiements"],
        "summary": "Lister les paiements",
