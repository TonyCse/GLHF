        },
        "responses": {
          "200": { "description": "Action effectuée" }
        }
      }
    },
    "/api/admin/tournaments/{id}/available-users": {
      "get": {
        "tags": ["Admin - Tournois"],
        "summary": "Lister les utilisateurs non encore participants",
