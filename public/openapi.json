        "responses": {
          "200": { "description": "Liste paginée des paiements" }
        }
      }
    },
    "/api/admin/payments/action": {
      "post": {
        "tags": ["Admin - Paiements"],
        "summary": "Effectuer une action sur un paiement",
        "requestBody": {
          "content": { "application/json": { "schema": { "type": "object", "properties": { "subscriptionId": { "type": "string" }, "action": { "type": "string", "enum": ["cancel", "suspend", "activate"] } } } } }
        },
        "responses": {
          "200": { "description": "Action effectuée" }
        }
      }
    },
    "/api/admin/contacts": {
      "get": {
        "tags": ["Admin - Contacts"],
